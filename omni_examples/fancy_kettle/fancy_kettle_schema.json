{
  "$schema": "https://json-schema.org/draft-07/schema",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "colour": {
      "enum": [
        "black",
        "white",
        "pink",
        "sage"
      ],
      "type": "string"
    },
    "temperature": {
      "maximum": 100,
      "minimum": 60,
      "type": "number"
    }
  },
  "required": [
    "colour",
    "temperature"
  ],
  "type": "object"
}